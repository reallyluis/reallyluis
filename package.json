{
  "name": "reallyluis",
  "version": "1.0.0",
  "description": "A personal website by reallyluis.",
  "scripts": {
    "prebuild": "rm -rf ./dist; mkdir dist; mkdir dist/css; mkdir dist/js; cp -R ./src/img ./dist/img; cp ./src/manifest.webmanifest ./dist/manifest.webmanifest",
    "build": "npm run prebuild && npm run minify:html && npm run minify:css && npm run minify:js && npm run minify:pwa",
    "minify:html": "minify ./src/index.html > ./dist/index.html",
    "minify:css": "minify ./src/css/style.css > ./dist/css/style.css",
    "minify:js": "minify ./src/js/index.js > ./dist/js/index.js",
    "minify:pwa": "minify ./src/service-worker.js > ./dist/service-worker.js",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "stylelint './src/css/**/*.css'",
    "lint:js": "eslint './src/js/**/*.js'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reallyluis/reallyluis.git"
  },
  "author": "reallyluis",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/reallyluis/reallyluis/issues"
  },
  "homepage": "https://github.com/reallyluis/reallyluis#readme",
  "devDependencies": {
    "eslint": "^7.11.0",
    "eslint-config-google": "^0.14.0",
    "minify": "^6.0.0",
    "stylelint": "^13.7.2",
    "stylelint-config-standard": "^20.0.0"
  }
}
