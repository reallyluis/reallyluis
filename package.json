{
  "name": "reallyluis",
  "version": "1.8.8",
  "description": "A personal website by reallyluis.",
  "scripts": {
    "emulators": "firebase emulators:start",
    "prebuild": "bash ./scripts/prebuild.sh",
    "build": "bash ./scripts/build.sh",
    "build:local": "bash ./scripts/build.sh local",
    "minify:html": "node ./scripts/minify-html.js",
    "minify:css": "node ./scripts/minify-css.js",
    "minify:js": "node ./scripts/minify-js.js",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "stylelint './src/css/**/*.css'",
    "lint:js": "eslint './src/js/**/*.js'",
    "test": "jest ./tests/*.test.js",
    "test:coverage": "jest ./tests/*.test.js --coverage"
  },
  "jest": {
    "verbose": true,
    "collectCoverageFrom": [
      "src/js/**",
      "!**/node_modules/**",
      "!**/public/**",
      "!**/tests/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 50,
        "branches": 50,
        "functions": 50,
        "lines": 75
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reallyluis/reallyluis.git"
  },
  "author": "reallyluis",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/reallyluis/reallyluis/issues"
  },
  "homepage": "https://github.com/reallyluis/reallyluis#readme",
  "devDependencies": {
    "eslint": "^7.11.0",
    "eslint-config-google": "^0.14.0",
    "jest": "^26.6.3",
    "minify": "^6.0.0",
    "stylelint": "^13.7.2",
    "stylelint-config-standard": "^20.0.0"
  },
  "dependencies": {
    "dotenv": "^8.2.0"
  }
}
