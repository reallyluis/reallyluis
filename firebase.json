{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'none'; connect-src 'self' https://reallyluis.com https://cdnjs.cloudflare.com https://*.googleapis.com  https://*.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://reallyluis.com; manifest-src 'self' https://reallyluis.com; script-src 'self' https://reallyluis.com; style-src 'self' 'sha256-5POpxENXwgfue2/s2k7RgKmN6Eshh/vc/WkVOWoyr8c=' https://reallyluis.com https://cdnjs.cloudflare.com https://fonts.googleapis.com; worker-src 'self' https://reallyluis.com"
          },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          { "key": "X-XSS-Protection", "value": "1; mode=block" }
        ]
      },
      {
        "source": "**/*.@(html|css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000"
          },
          {
            "key": "Content-Encoding",
            "value": "br"
          }
        ]
      },
      {
        "source": "**/*.@(webp|png)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000"
          },
          {
            "key": "Content-Encoding",
            "value": "br"
          }
        ]
      }
    ]
  },
  "functions": {
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  }
}
