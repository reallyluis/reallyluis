{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self' *.cloudflare.com *.googleapis.com *.gstatic.com 'sha256-JayP1EzfIjFOGQLrTq1RFlUeM/OIWya8BN1dK6OsbAU=' 'sha256-9nfz2oIUGZvkypnhrSfUjc/09HFxSmtaQpEpJwmLAxs='"
          },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          { "key": "X-XSS-Protection", "value": "1; mode=block" }
        ]
      },
      {
        "source": "**/*.@(html|css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000"
          },
          {
            "key": "Content-Encoding",
            "value": "br"
          }
        ]
      },
      {
        "source": "**/*.@(webp|png)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000"
          },
          {
            "key": "Content-Encoding",
            "value": "br"
          }
        ]
      }
    ]
  },
  "functions": {
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  }
}
