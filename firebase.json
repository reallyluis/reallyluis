{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [ {
      "source": "**/*.@(css|js)",
      "headers": [ {
        "key": "Cache-Control",
        "value": "public, max-age=86400"
      } ]
    }, {
      "source": "**/*.@(webp|png)",
      "headers": [ {
        "key": "Cache-Control",
        "value": "public, max-age=2592000"
      } ]
    } ]
  },
  "functions": {
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ],
    "source": "functions"
  }
}
